@page
@model UserCreateAccountPageModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_ExternalLayout";
}

<div class="container py-4">
    <div class="card bg-secondary bg-opacity-10 border-secondary-subtle rounded-3">
        <div class="card-header bg-secondary bg-opacity-25 border-secondary-subtle text-center">
            <span class="fw-semibold text-light">Enter your information to create account and make a reservation</span>
        </div>

        <div class="card-body p-4">
            <div class="bg-secondary bg-opacity-25 rounded-3 p-5">
                <form method="post" class="mx-auto" style="max-width: 420px;">
                    <div class="row mb-3">
                        <div class="col-6">
                            <label asp-for="FirstName" class="form-label text-light fw-semibold">First Name</label>
                            <input asp-for="FirstName" class="form-control bg-dark text-light border-secondary-subtle" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="LastName" class="form-label text-light fw-semibold">Last Name</label>
                            <input asp-for="LastName" class="form-control bg-dark text-light border-secondary-subtle" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label text-light fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control bg-dark text-light border-secondary-subtle" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label text-light fw-semibold">Password</label>
                        <input asp-for="Password" type="password" class="form-control bg-dark text-light border-secondary-subtle" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label text-light fw-semibold">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control bg-dark text-light border-secondary-subtle" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-info text-dark fw-semibold px-4">Create Account</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="text-center text-light mt-3">
        Having trouble?: <a asp-page="/ContactUs" class="link-info text-decoration-none">Contact us</a>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
