@page
@model ReservationService.Pages.Employee.AlternativePaymentsModel

<div class="form-container">
    <h2 class="page-title">Record Alternative Payment</h2>

    <form method="post" class="styled-form">

        <label class="form-label">Payment Method</label>
        <select asp-for="PaymentMethod" class="form-input">
            <option value="">-- Select Method --</option>
            <option>Cash</option>
            <option>Check</option>
            <option>Manual Credit Card Entry</option>
        </select>

        <label class="form-label">Amount</label>
        <input asp-for="Amount" class="form-input" type="number" step="0.01" />

        <label class="form-label">Reference / Notes</label>
        <textarea asp-for="Notes" class="form-textarea"
                  placeholder="Check number, last 4 digits of card, cashier notes, etc."></textarea>

        <button type="submit" class="primary-button">Record Payment</button>
    </form>

    @if (!string.IsNullOrEmpty(Model.ConfirmationMessage))
    {
        <div class="confirmation-box">
            <p>@Model.ConfirmationMessage</p>
        </div>
    }
</div>
