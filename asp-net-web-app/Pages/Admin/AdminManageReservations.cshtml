@page "{handler?}/{id?}"
@model asp_net_web_app.Pages.AdminManageReservationsModel
@{
    ViewData["Title"] = "Admin - Manage Reservations";
    ViewData["Page"]  = "Reservations";
}

<style>
    .admin-container { padding: 2.5rem 3rem; color: #e5e5e5; background-color: transparent; min-height: 100vh; }
    .flex-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .btn-custom-primary { background-color: #4f46e5; color: white; padding: 0.6rem 1.2rem; border-radius: 0.5rem; font-weight: 500; text-decoration: none; border: none; cursor: pointer; }
    .btn-custom-primary:hover { background-color: #4338ca; }
    .data-card { background-color: #171717; border: 1px solid #262626; border-radius: 0.75rem; padding: 1.5rem; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3); margin-bottom: 2rem; }
    .admin-table { width: 100%; border-collapse: collapse; text-align: left; }
    .admin-table th { padding: 1rem; border-bottom: 1px solid #262626; color: #a3a3a3; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
    .admin-table td { padding: 1rem; border-bottom: 1px solid #262626; font-size: 0.875rem; }
    .form-group { margin-bottom: 1.25rem; }
    .form-label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #a3a3a3; margin-bottom: 0.5rem; }
    .form-input-field { width: 100%; background-color: #0a0a0a; color: white; border: 1px solid #262626; border-radius: 0.5rem; padding: 0.6rem 0.75rem; outline: none; font-size: 0.875rem; }
    .form-input-field:focus { border-color: #4f46e5; }
    .btn-grid-action { background: #262626; color: #d4d4d4; border: 1px solid #404040; padding: 0.4rem 0.75rem; border-radius: 0.375rem; text-decoration: none; font-size: 0.75rem; cursor: pointer; }
    .btn-grid-action:hover { background: #404040; color: white; }
    .badge-status { padding: 0.2rem 0.5rem; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 500; background-color: #262626; color: #d4d4d4; }
</style>

<div class="admin-container">

    @if (Model.BalanceDiff.HasValue)
    {
        <div class="data-card" style="border-color: @(Model.BalanceDiff >= 0 ? "#f59e0b" : "#34d399");">
            <p style="margin:0; color:white;">
                Balance adjustment from last edit:
                <strong style="color:@(Model.BalanceDiff >= 0 ? "#fbbf24" : "#34d399");">
                    @(Model.BalanceDiff >= 0 ? "+" : "")@Model.BalanceDiff.Value.ToString("F2")
                </strong>
                (@(Model.BalanceDiff >= 0 ? "additional payment due" : "refund owed"))
            </p>
        </div>
    }

    @if (Model.CurrentAction == "List")
    {
        <div class="flex-header">
            <div>
                <h1 style="font-size: 1.5rem; font-weight: 600; color: white; margin: 0;">Reservation Management</h1>
                <p style="font-size: 0.875rem; color: #a3a3a3; margin: 0.25rem 0 0 0;">Search, edit, and cancel guest reservations.</p>
            </div>
            <a asp-page-handler="CreateReservation" class="btn-custom-primary">+ New Reservation</a>
        </div>

        <div class="data-card" style="padding:1rem 1.5rem;">
            <form method="get">
                <div style="display:flex; gap:0.75rem; align-items:end;">
                    <div style="flex:1;">
                        <label class="form-label">Search by Reservation # or Customer Name</label>
                        <input name="search" class="form-input-field" value="@Model.SearchTerm" placeholder="e.g. 3 or Alice" />
                    </div>
                    <button type="submit" class="btn-custom-primary">Search</button>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <a asp-page="" class="btn-grid-action">Clear</a>
                    }
                </div>
            </form>
        </div>

        <div class="data-card" style="padding: 0; overflow: hidden;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="padding-left:1.5rem;">Res #</th>
                        <th>Customer</th>
                        <th>Site</th>
                        <th>Dates</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th style="text-align:right; padding-right:1.5rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AllReservations.Any())
                    {
                        @foreach (var r in Model.AllReservations)
                        {
                            <tr>
                                <td style="padding-left:1.5rem; font-weight:600; color:white;">#@r.Id</td>
                                <td>@r.CustomerName</td>
                                <td><span class="badge-status">@r.SiteNumber</span></td>
                                <td>@r.StartDate.ToShortDateString() – @r.EndDate.ToShortDateString()</td>
                                <td>@r.Status</td>
                                <td>$@r.TotalCost.ToString("F2")</td>
                                <td style="text-align:right; padding-right:1.5rem;">
                                    <a asp-page-handler="CreateReservation" asp-route-id="@r.Id" class="btn-grid-action" style="color:#6366f1;">Edit</a>
                                    @if (r.Status != "Cancelled")
                                    {
                                        <form method="post" asp-page-handler="CancelReservation" asp-route-id="@r.Id" style="display:inline;" onclick="return confirm('Cancel this reservation?');">
                                            <button type="submit" class="btn-grid-action" style="color:#fbbf24;">Cancel</button>
                                        </form>
                                    }
                                    <form method="post" asp-page-handler="DeleteReservation" asp-route-id="@r.Id" style="display:inline;" onclick="return confirm('Delete permanently?');">
                                        <button type="submit" class="btn-grid-action" style="color:#f87171;">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" style="text-align:center; color:#737373; padding:2rem;">No reservations found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (Model.CurrentAction == "Create" || Model.CurrentAction == "Edit")
    {
        <div style="margin-bottom: 1.5rem;">
            <a asp-page="" style="font-size: 0.75rem; color: #a3a3a3; text-decoration: none;">← Back to Reservations</a>
            <h1 style="font-size: 1.25rem; font-weight: 600; color: white; margin-top: 0.5rem;">
                @(Model.CurrentAction == "Create" ? "New Reservation" : $"Edit Reservation #{Model.ActiveId}")
            </h1>
        </div>

        <div class="data-card" style="max-width: 500px;">
            <form method="post" asp-page-handler="@(Model.CurrentAction == "Edit" ? "UpdateReservation" : "CreateReservation")">
                <input type="hidden" name="reservationId" value="@Model.ActiveId" />

                <div class="form-group">
                    <label class="form-label">Customer</label>
                    <select name="userId" class="form-input-field">
                        @foreach (var u in Model.AllUsers)
                        {
                            <option value="@u.userId" selected="@(u.userId == Model.ActiveUserId)">@u.firstName @u.lastName (#@u.userId)</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Site</label>
                    <select name="siteId" class="form-input-field">
                        @foreach (var s in Model.AllSites)
                        {
                            <option value="@s.Id" selected="@(s.Id == Model.ActiveSiteId)">@s.SiteNumber (@s.Category)</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-input-field" value="@Model.ActiveStartDate.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="form-group">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-input-field" value="@Model.ActiveEndDate.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-input-field">
                        @foreach (var opt in new[] { "Upcoming", "In Progress", "Completed", "Cancelled" })
                        {
                            <option value="@opt" selected="@(opt == Model.ActiveStatus)">@opt</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Total Cost ($)</label>
                    <input type="number" step="0.01" name="totalCost" class="form-input-field" value="@Model.ActiveCost" required />
                </div>

                <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #262626;">
                    <button type="submit" class="btn-custom-primary" style="background-color: #10b981;">
                        @(Model.CurrentAction == "Edit" ? "Update Reservation" : "Create Reservation")
                    </button>
                    <a asp-page="" class="btn-grid-action" style="padding: 0.6rem 1.2rem; font-size: 0.875rem; border-radius: 0.5rem;">Cancel</a>
                </div>
            </form>
        </div>
    }
</div>