@page
@model asp_net_web_app.Pages.CreateModel
@{
    ViewData["Title"] = "Employee";
    ViewData["Page"]  = "Create Employee";
}

<body class="app-shell">
    <!-- Main content -->
    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">Create Employee Account</h1>
        </div>

        <div class="card">
            <div class="card-title">Employee Details</div>

            <form method="post">

                <div class="mb-3">
                    <label asp-for="Employee.firstName" class="form-label">First Name</label>
                    <input asp-for="Employee.firstName" class="form-control" placeholder="John" />
                    <span asp-validation-for="Employee.firstName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Employee.lastName" class="form-label">Last Name</label>
                    <input asp-for="Employee.lastName" class="form-control" placeholder="Doe" />
                    <span asp-validation-for="Employee.lastName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Employee.dateOfBirth" class="form-label">Date of Birth</label>
                    <input asp-for="Employee.dateOfBirth" type="date" class="form-control" />
                    <span asp-validation-for="Employee.dateOfBirth" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Employee.username" class="form-label">Username</label>
                    <input asp-for="Employee.username" class="form-control" placeholder="jdoe" />
                    <span asp-validation-for="Employee.username" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Employee.password" class="form-label">Password</label>
                    <input asp-for="Employee.password" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Employee.password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Employee.role" class="form-label">Role</label>
                    <select asp-for="Employee.role" class="form-select">
                        <option value="">Select role...</option>
                        <option>Admin</option>
                        <option>Employee</option>
                    </select>
                    <span asp-validation-for="Employee.role" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Create Account</button>
                <a href="/Employees" class="btn btn-danger">Cancel</a>
            </form>
        </div>
    </div>
</body>