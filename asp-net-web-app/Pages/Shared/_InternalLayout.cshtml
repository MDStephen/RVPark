<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reservation Manager</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/asp_net_web_app.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">

    <!-- ── Sidebar ───────────────────────────────────────── -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-clipboard2-check brand-icon"></i>
            <span class="brand-text">Reservation<br>Manager</span>
        </div>

        <nav class="sidebar-nav">
            <ul class="nav flex-column">
                <li class="nav-item"><a class="nav-link d-flex align-items-center gap-2 px-3 py-2 text-white" asp-area="" asp-page="/Dashboard"><i class="bi bi-grid nav-icon"></i><span class="fs-6">Dashboard</span></a></li>
                <li class="nav-item"><a class="nav-link d-flex align-items-center gap-2 px-3 py-2 text-white" asp-area="" asp-page="/Admin/AdminManageReservations"><i class="bi bi-calendar3 nav-icon"></i><span class="fs-6">Reservations</span></a></li>
                <li class="nav-item"><a class="nav-link d-flex align-items-center gap-2 px-3 py-2 text-white" asp-area="" asp-page="/Customers"><i class="bi bi-person nav-icon"></i><span class="fs-6">Customers</span></a></li>
                <li class="nav-item"><a class="nav-link d-flex align-items-center gap-2 px-3 py-2 text-white" asp-area="" asp-page="/Sites"><i class="bi bi-geo-alt nav-icon"></i><span class="fs-6">Sites</span></a></li>
                <li class="nav-item"><a class="nav-link d-flex align-items-center gap-2 px-3 py-2 text-white" asp-area="" asp-page="/Admin/AdminReportGenerator"><i class="bi bi-bar-chart nav-icon"></i><span class="fs-6">Reports</span></a></li>
                <li class="nav-item"><a class="nav-link d-flex align-items-center gap-2 px-3 py-2 text-white" asp-area="" asp-page="/Admin/Pricing"><i class="bi bi-cash-coin nav-icon"></i><span class="fs-6">Pricing</span></a></li>
                <li class="nav-item"><a class="nav-link d-flex align-items-center gap-2 px-3 py-2 text-white" asp-area="" asp-page="/Admin/ManageUsers"><i class="bi bi-people nav-icon"></i><span class="fs-6">Users</span></a></li>
                <li class="nav-item"><a class="nav-link d-flex align-items-center gap-2 px-3 py-2 text-white" asp-area="" asp-page="/Admin/AdminManageSite"><i class="bi bi-building-gear nav-icon"></i><span class="fs-6">Manage Site</span></a></li>
            </ul>
        </nav>

        <div class="sidebar-footer">
            <div class="avatar-circle">
                <i class="bi bi-person-circle"></i>
            </div>
        </div>
    </aside>

    <!-- ── Main content ──────────────────────────────────── -->
    <main class="main-content" role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
