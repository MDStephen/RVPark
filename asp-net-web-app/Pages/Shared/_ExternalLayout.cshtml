@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RVPark</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100 bg-dark">
    <!-- ===== Navigation Bar ===== -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary" style="--bs-bg-opacity: .25;">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/CustomerFacing/Index">RVPARK</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#extNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="extNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/CustomerFacing/Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/link1">link1</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/link2">link2</a></li>
                        <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Admin/Dashboard">temporary link to dashboard</a></li>
                        <li class="nav-item">
                            <a class="btn btn-primary text-white fw-semibold ms-lg-2" asp-area="" asp-page="/CustomerFacing/UserLoginPage">Log In</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <!-- ===== Page Body ===== -->
    <main class="flex-grow-1 bg-dark">
        @RenderBody()
    </main>
    <!-- ===== Footer ===== -->
    <footer class="bg-dark bg-gradient text-light mt-auto">
        <div class="container py-4">
            <div class="row gy-3">
                <div class="col-md-4">
                    <h5>RVPARK</h5>
                    <p class="mb-0">address<br />City, UT area_code</p>
                </div>
                <div class="col-md-4">
                    <h5>Contact</h5>
                    <p class="mb-0">phone number<br />email</p>
                </div>
            </div>
        </div>
        <div class="text-center border-top border-secondary py-2 small">
            &copy; @DateTime.Now.Year RVPARK. All rights reserved.
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
