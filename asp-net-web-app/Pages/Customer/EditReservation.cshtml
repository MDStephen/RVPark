@page
@model ReservationService.Pages.Reservations.EditReservationModel

<div class="form-container">
    <h2 class="page-title">Edit Reservation</h2>

    <form method="post" asp-page-handler="CheckAvailability" class="styled-form">
        <input type="hidden" asp-for="Reservation.ReservationId" />

        <label class="form-label">Check-In Date</label>
        <input asp-for="Reservation.CheckIn" type="date" class="form-input" />

        <label class="form-label">Check-Out Date</label>
        <input asp-for="Reservation.CheckOut" type="date" class="form-input" />

        <label class="form-label">Site Type</label>
        <select asp-for="Reservation.SiteType" class="form-input">
            <option value="Tent">Tent</option>
            <option value="RV">RV</option>
            <option value="Trailer">Trailer</option>
            <option value="Group Site">Group Site</option>
        </select>

        <label class="form-label">RV / Vehicle Length</label>
        <input asp-for="Reservation.VehicleLength" type="number" class="form-input" />

        <button type="submit" class="primary-button">Check Availability</button>
    </form>

    <div class="pricing-box">
        <p><strong>Original Price:</strong> $@Model.OriginalPrice</p>
        <p><strong>Updated Price:</strong> $@Model.UpdatedPrice</p>
        <p><strong>Difference:</strong> $@Model.PriceDifference</p>
    </div>

    @if (Model.AvailableSites.Any())
    {
        <h3 class="page-title">Available Campsites</h3>
        <div class="results-container">
            @foreach (var site in Model.AvailableSites)
            {
                <div class="result-card">
                    <h4>@site.Name</h4>
                    <p>Type: @site.SiteType</p>
                    <p>Max Length: @site.MaxLength ft</p>

                    <form method="post" asp-page-handler="Save">
                        <input type="hidden" name="campsiteId" value="@site.CampsiteId" />
                        <button class="primary-button">Save Changes</button>
                    </form>
                </div>
            }
        </div>
    }

    <form method="post" asp-page-handler="Cancel">
        <input type="hidden" name="id" value="@Model.Reservation.ReservationId" />
        <button class="primary-button" style="background-color:#c62828;">Cancel Reservation</button>
    </form>